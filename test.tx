threadlocal i32 a = 0 - 1;

enum Bee {
	What = { 1 << 3 },
	Gwhor = 1 << 3 ,
	How,
}

struct Xexor {
	bool no;
	str yes;
}

union Testor {
	i32 faah;
	u8 grug;
}

async inline i32 get_a(bool x) {
	ret {
		if (x) {
			a - 1
		} else {
			a
		}
	};
}

// The main function
u8 main(u32 argc, str[] argv) {
	i32 va = get_a(false);
	i32 b = get_a(true) + 1;

	for (mut u32 i = 0; i < argc; i++) {
		va++;
		b += i;
	}

	u8[3] rarray =  [ 3, 5, { 5 } ];

	while (b < 100) {
		b *= 3;
	}
	rarray[a] += b;

	b = { 0 };

	defer { b + 3 };
	defer  b + 3;

	ret b;
}
