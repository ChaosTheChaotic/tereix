i32 a = 0 - 1;

i32 get_a(bool x) {
	ret {
		if (x) {
			a - 1
		} else {
			a
		}
	};
}

// The main function
u8 main(u32 argc, str[] argv) {
  i32 va = get_a(false);
  i32 b = get_a(true) + 1;

	for (mut u32 i = 0; i < argc; i++) {
		va++;
		b += i;
	}

	while (b < 100) {
		b *= 3;
	}

	b = { 0 };

  ret b;
}
